{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "types": ["node"],
    "isolatedModules": true,
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./"
  }
}
