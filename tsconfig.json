{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "types": ["node"] ,
    "isolatedModules": true,
    "moduleResolution": "Node16",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
  }
}
