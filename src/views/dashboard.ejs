<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NexusFlow | Administrative Recon Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-900 text-slate-100 font-sans min-h-screen">

  <!-- Header Perimeter -->
  <header class="border-b border-slate-800 bg-slate-950/50 backdrop-blur sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <!-- <span class="text-2xl">🚀</span> -->
        <h1 class="text-xl font-bold tracking-tight bg-gradient-to-r from-teal-400 to-cyan-400 bg-clip-text text-transparent">NexusFlow Engine</h1>
      </div>
      <div class="flex items-center space-x-4">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
          <span class="w-1.5 h-1.5 mr-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          System Online
        </span>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
    
        <!-- Real-Time Background Worker Metrics Widgets -->
    <section class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-6"> <!-- 🔥 Changed from md:grid-cols-4 to md:grid-cols-5 -->
      <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-400 uppercase tracking-wider">Worker Thread Status</p>
        <p id="worker-status-txt" class="mt-2 text-3xl font-semibold text-teal-400"><%= worker.status %></p>
      </div>
      <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-400 uppercase tracking-wider">Queue Backlog Size</p>
        <p id="backlog-count-txt" class="mt-2 text-3xl font-semibold text-cyan-400"><%= worker.backlogCount %> pending</p>
      </div>
      <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-400 uppercase tracking-wider">Unresolved Queue</p>
        <p class="mt-2 text-3xl font-semibold text-amber-500"><%= meta.totalRecords %> cases</p>
      </div>
      <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-400 uppercase tracking-wider">Avg Resolution Speed</p>
        <p class="mt-2 text-3xl font-semibold text-emerald-400"><%= meta.avgResolutionSpeed %></p>
      </div>
      <!-- Real-Time Active Table Disk Utilization Widget Tile -->
      <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-400 uppercase tracking-wider">Active Table Size</p>
        <p class="mt-2 text-3xl font-semibold text-fuchsia-400"><%= meta.tableDiskSize %></p>
      </div>
    </section>



    <!-- Flagged Transactions Management Workspace -->
    <section class="bg-slate-950 border border-slate-800 rounded-xl shadow-xl overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-800 flex justify-between items-center">
        <h2 class="text-lg font-semibold text-slate-200">Human Review Exception Queue</h2>
        <span class="text-sm text-slate-400">Showing page <%= meta.currentPage %> of <%= meta.totalPages || 1 %></span>
      </div>
<div class="w-full sm:w-72">
          <input 
            type="text" 
            id="table-search-input" 
            onkeyup="executeFuzzySearch()" 
            placeholder="Search exceptions (merchant, ID, amount)..." 
            class="w-full bg-slate-900 border border-slate-800 rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-teal-500 transition-colors"
          />
        </div>
      </div>
      <% if (transactions.length === 0) { %>
        <div class="p-12 text-center text-slate-500 space-y-2">
          <p class="text-4xl">🎉</p>
          <p class="text-lg font-medium">All clear! No transactions currently need review.</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-900/50 text-slate-400 text-xs font-semibold tracking-wider uppercase border-b border-slate-800">
                <th class="px-6 py-4">Transaction Details</th>
                <th class="px-6 py-4">Source</th>
                <th class="px-6 py-4">Amount</th>
                <th class="px-6 py-4">Date Flagged</th>
                <th class="px-6 py-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800/60 text-sm">
              <% transactions.forEach(tx => { %>
                <tr class="hover:bg-slate-900/30 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-200">
                    <div class="font-semibold"><%= tx.description %></div>
                    <div class="text-xs text-slate-500 font-mono mt-0.5"><%= tx.id %></div>
                  </td>
                  <td class="px-6 py-4">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= tx.source === 'BANK' ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20' : 'bg-purple-500/10 text-purple-400 border border-purple-500/20' %>">
                      <%= tx.source %>
                    </span>
                  </td>
                  <td class="px-6 py-4 font-mono font-semibold text-slate-300">
                    $<%= parseFloat(tx.amount).toLocaleString(undefined, { minimumFractionDigits: 2 }) %>
                  </td>
                  <td class="px-6 py-4 text-slate-400">
                    <%= new Date(tx.createdAt).toLocaleDateString() %>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <button onclick="resolveManually('<%= tx.id %>')" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-semibold rounded-lg text-slate-950 bg-teal-400 hover:bg-teal-300 shadow-sm focus:outline-none transition-all">
                      Resolve Pairing
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
        <!--  Historical Audit Trail Section Log Queue -->
    <section class="bg-slate-950 border border-slate-800 rounded-xl shadow-xl overflow-hidden mt-8">
      <div class="px-6 py-5 border-b border-slate-800">
        <h2 class="text-lg font-semibold text-slate-200">Historical Manual Resolutions Log</h2>
        <p class="text-xs text-slate-500 mt-0.5">Audit log displaying recently paired exception tracks</p>
      </div>
      <div>
          <a href="/analytics/export-csv" class="inline-flex items-center px-4 py-2 text-xs font-semibold rounded-lg text-teal-400 border border-teal-500/30 bg-teal-500/10 hover:bg-teal-500/20 shadow-sm focus:outline-none transition-all">
            Download Audit CSV
          </a>
        </div>


      <% if (history.length === 0) { %>
        <div class="p-8 text-center text-slate-600 text-sm">
          No historical manual resolutions recorded for this station run yet.
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-900/50 text-slate-400 text-xs font-semibold tracking-wider uppercase border-b border-slate-800">
                <th class="px-6 py-4">Bank Transaction ID</th>
                <th class="px-6 py-4">Internal Partner ID</th>
                <th class="px-6 py-4">Resolution Duration</th>
                <th class="px-6 py-4 text-right">Timestamp Locked</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800/40 text-xs font-mono text-slate-400">
              <% history.forEach(log => { %>
                <tr class="hover:bg-slate-900/10 transition-colors">
                  <td class="px-6 py-4 text-slate-300 font-semibold"><%= log.bankTransactionId %></td>
                  <td class="px-6 py-4 text-slate-300"><%= log.internalRecordId %></td>
                  <td class="px-6 py-4">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/10">
                      ⏱ <%= log.secondsToResolve %> seconds
                    </span>
                  </td>
                  <td class="px-6 py-4 text-right text-slate-500">
                    <%= new Date(log.resolvedAt).toLocaleString() %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>

  </main>

  <script>

    async function updateLiveMetrics() {
      try {
        const response = await fetch('/queue/status', {
          headers: {
            'X-API-KEY': 'nexus_secret_secure_key_2026'
          }
        });
        const data = await response.json();
        
        if (data.success) {
          const statusTxt = document.getElementById('worker-status-txt');
          const backlogTxt = document.getElementById('backlog-count-txt');
          
          if (statusTxt) statusTxt.innerText = data.worker.status;
          if (backlogTxt) backlogTxt.innerText = data.worker.backlogCount + " pending";
          
          if (statusTxt) {
            if (data.worker.status === 'PROCESSING') {
              statusTxt.className = "mt-2 text-3xl font-semibold text-amber-400 animate-pulse";
            } else {
              statusTxt.className = "mt-2 text-3xl font-semibold text-teal-400";
            }
          }
        }
      } catch (err) {
        console.warn("[Metrics Sync] Remote background telemetry poll timed out.");
      }
    }

    // Run the metric scanner update loop automatically every 3 seconds
    setInterval(updateLiveMetrics, 3000);

    // Manual Override resolution handler
    async function resolveManually(bankId) {
      const internalId = prompt("Please input the matching internal transaction UUID token:");
      if (!internalId) return;

      try {
        const response = await fetch('/transactions/resolve', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-API-KEY': 'nexus_secret_secure_key_2026'
          },
          body: JSON.stringify({ bankTransactionId: bankId, internalRecordId: internalId })
        });
        
        const data = await response.json();
        if (data.success) {
          alert("Success! Transactions linked and flagged status resolved.");
          window.location.reload();
        } else {
          alert("Error: " + data.details);
        }
      } catch (err) {
        alert("Execution failure connecting to API server.");
      }
    }
        // 🔥 NEW: Instant Client-Side Fuzzy Search Logic
    function executeFuzzySearch() {
      const input = document.getElementById("table-search-input");
      const filter = input.value.toLowerCase().trim();
      const table = document.querySelector("table");
      
      if (!table) return; // If the queue is empty, do nothing
      
      const rows = table.getElementsByTagName("tbody")[0].getElementsByTagName("tr");

      // Loop through all table rows, hiding those that don't match the search query
      for (let i = 0; i < rows.length; i++) {
        const textContent = rows[i].textContent.toLowerCase();
        
        if (textContent.includes(filter)) {
          rows[i].style.display = ""; // Show matching row
        } else {
          rows[i].style.display = "none"; // Hide non-matching row
        }
      }
    }

  </script>
</body>
</html>

</body>
</html>
